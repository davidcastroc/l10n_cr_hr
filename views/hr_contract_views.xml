<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="view_contract_form_cr_payroll" model="ir.ui.view">
        <field name="name">hr.contract.form.cr.payroll</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="priority">30</field>

        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">

                <page
                    name="cr_payroll_information"
                    string="Costa Rica"
                >

                    <group>

                        <group string="Configuración salarial">

                            <field name="cr_salary_mode"/>

                            <field name="cr_pay_frequency"/>

                            <field name="wage" readonly="1"/>

                        </group>

                        <group string="Jornada laboral">

                            <field name="cr_journey_type"/>

                            <field name="cr_hours_per_day"/>

                            <field name="cr_days_divisor"/>

                        </group>

                    </group>

                    <group string="Políticas de vacaciones">

                        <group>

                            <field name="cr_allow_advanced_leave"/>

                        </group>

                    </group>

                </page>

            </xpath>

        </field>
    </record>

</odoo>