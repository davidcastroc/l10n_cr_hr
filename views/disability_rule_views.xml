<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cr_disability_rule_list" model="ir.ui.view">
        <field name="name">cr.payroll.disability.rule.list</field>
        <field name="model">cr.payroll.disability.rule</field>
        <field name="arch" type="xml">
            <list string="Reglas de incapacidad y licencias">
                <field name="name"/>
                <field name="code"/>
                <field name="day_from"/>
                <field name="day_to"/>
                <field name="deduction_rate"/>
                <field name="employer_rate"/>
                <field name="subsidy_rate"/>
                <field name="subsidy_paid_in_payroll"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_cr_disability_rule_form" model="ir.ui.view">
        <field name="name">cr.payroll.disability.rule.form</field>
        <field name="model">cr.payroll.disability.rule</field>
        <field name="arch" type="xml">
            <form string="Regla de incapacidad o licencia">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="leave_type_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="day_from"/>
                            <field name="day_to"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Cálculo">
                        <field name="deduction_rate"/>
                        <field name="employer_rate"/>
                        <field name="subsidy_rate"/>
                        <field name="subsidy_paid_in_payroll"/>
                    </group>
                    <group string="Tratamiento del pago patronal">
                        <field name="employer_payment_taxable"/>
                        <field name="employer_payment_taxable_income"/>
                        <field name="affects_aguinaldo"/>
                        <field name="affects_vacation"/>
                    </group>
                    <group>
                        <field name="source"/>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_cr_disability_rule" model="ir.actions.act_window">
        <field name="name">Reglas de incapacidad</field>
        <field name="res_model">cr.payroll.disability.rule</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
