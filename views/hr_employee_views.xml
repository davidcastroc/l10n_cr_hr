<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_cr_payroll" model="ir.ui.view">
        <field name="name">hr.employee.form.cr.payroll</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='identification_id']" position="after">
                <field name="cr_identification_type"/>
                <field name="cr_social_security_number"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Nómina Costa Rica" name="cr_payroll_information">
                    <group>
                        <group string="Saldos iniciales">
                            <field name="cr_vacation_opening_days"/>
                            <field name="cr_vacation_opening_date"/>
                            <field name="cr_aguinaldo_opening_earnings"/>
                            <field name="cr_aguinaldo_opening_days"/>
                            <field name="cr_aguinaldo_opening_date"/>
                        </group>
                        <group string="Renta salarial">
                            <field name="cr_tax_children" readonly="1"/>
                            <field name="cr_tax_spouse" readonly="1"/>
                            <field name="cr_tax_dependent_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="identification"/>
                                    <field name="dependent_type"/>
                                    <field name="date_from"/>
                                    <field name="date_to"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </group>
                    </group>
                    <group string="Deducciones recurrentes">
                        <field name="cr_payroll_deduction_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="priority"/>
                                <field name="name"/>
                                <field name="deduction_type"/>
                                <field name="calculation"/>
                                <field name="amount"/>
                                <field name="percentage"/>
                                <field name="balance"/>
                                <field name="frequency"/>
                                <field name="date_from"/>
                                <field name="date_to"/>
                                <field name="active"/>
                            </list>
                        </field>
                    </group>
                    <group>
                        <field name="cr_opening_notes"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
