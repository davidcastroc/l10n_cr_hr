<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cr_generate_holidays_wizard" model="ir.ui.view">
        <field name="name">cr.generate.holidays.wizard.form</field>
        <field name="model">cr.generate.holidays.wizard</field>
        <field name="arch" type="xml">
            <form string="Generar feriados CR">
                <group>
                    <field name="year"/>
                </group>
                <footer>
                    <button name="action_generate"
                            type="object"
                            string="Generar"
                            class="btn-primary"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cr_generate_holidays" model="ir.actions.act_window">
        <field name="name">Generar feriados CR</field>
        <field name="res_model">cr.generate.holidays.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_cr_generate_holidays"
              name="Generar feriados"
              parent="menu_cr_payroll_root"
              action="action_cr_generate_holidays"
              sequence="80"/>
</odoo>
