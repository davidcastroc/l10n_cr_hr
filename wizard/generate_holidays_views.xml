<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cr_generate_holidays_wizard" model="ir.ui.view">
        <field name="name">cr.generate.holidays.wizard.form</field>
        <field name="model">cr.generate.holidays.wizard</field>
        <field name="arch" type="xml">
            <form string="Generar feriados de Costa Rica">
                <sheet>
                    <group>
                        <field name="year" string="Año"/>
                    </group>
                </sheet>

                <footer>
                    <button
                        name="action_generate"
                        type="object"
                        string="Generar feriados"
                        class="btn-primary"
                    />

                    <button
                        string="Cancelar"
                        special="cancel"
                        class="btn-secondary"
                    />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cr_generate_holidays" model="ir.actions.act_window">
        <field name="name">Generar feriados de Costa Rica</field>
        <field name="res_model">cr.generate.holidays.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_cr_generate_holidays_wizard"/>
        <field name="target">new</field>
    </record>

</odoo>